# Neon Configuration Placeholders
# Copy this file to .env and fill in the values.

# VITE variables are exposed to the browser
VITE_NEON_AUTH_URL=https://your-neon-project.auth.us-east-2.aws.neon.tech
VITE_NEON_DATA_API_URL=https://your-neon-project.us-east-2.aws.neon.tech/sql

# Backend only variables (DO NOT prefix with VITE_)
# Used only by the migration script
DATABASE_URL=postgres://user:password@ep-something.us-east-2.aws.neon.tech/neondb
