rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isNumber(value) {
      return value is int || value is float;
    }

    function validDate(value) {
      return value is string && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function validTime(value) {
      return value is string && value.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function validProfile(data, userId) {
      return data.keys().hasOnly(['name', 'email', 'createdAt', 'photoURL'])
        && data.keys().hasAll(['name', 'email', 'createdAt'])
        && data.name is string
        && data.name.size() > 0
        && data.email is string
        && data.createdAt is string
        && (!data.keys().hasAny(['photoURL']) || data.photoURL is string)
        && request.auth.uid == userId;
    }

    function validSettings(data, userId) {
      return data.keys().hasOnly([
          'userId', 'salaryType', 'salaryAmount', 'workHoursPerDay', 'theme', 'updatedAt'
        ])
        && data.keys().hasAll([
          'userId', 'salaryType', 'salaryAmount', 'workHoursPerDay', 'theme', 'updatedAt'
        ])
        && data.userId == userId
        && data.userId == request.auth.uid
        && data.salaryType in ['daily', 'hourly']
        && isNumber(data.salaryAmount)
        && data.salaryAmount > 0
        && isNumber(data.workHoursPerDay)
        && data.workHoursPerDay >= 1
        && data.workHoursPerDay <= 24
        && data.theme in ['light', 'dark']
        && data.updatedAt is string;
    }

    function validAttendance(data, docId) {
      let keys = data.keys();
      let isWork = data.status == 'work';
      let hasCheckout = keys.hasAny(['checkOut']);
      let hasTotal = keys.hasAny(['totalHours']);
      return keys.hasOnly([
          'userId', 'date', 'checkIn', 'checkOut', 'totalHours',
          'note', 'status', 'createdAt', 'updatedAt'
        ])
        && keys.hasAll(['userId', 'date', 'checkIn', 'status', 'createdAt', 'updatedAt'])
        && data.userId == request.auth.uid
        && validDate(data.date)
        && docId == request.auth.uid + '_' + data.date
        && data.status in ['work', 'leave', 'off']
        && data.createdAt is string
        && data.updatedAt is string
        && (!keys.hasAny(['note']) || data.note is string)
        && (
          (isWork
            && validTime(data.checkIn)
            && (!hasCheckout || validTime(data.checkOut))
            && (hasCheckout == hasTotal)
            && (!hasTotal || (isNumber(data.totalHours) && data.totalHours > 0 && data.totalHours <= 24)))
          ||
          (!isWork && data.checkIn == '' && !hasCheckout && !hasTotal)
        );
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && validProfile(request.resource.data, userId);
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /settings/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create, update: if signedIn() && validSettings(request.resource.data, userId);
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /attendance/{docId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && validAttendance(request.resource.data, docId);
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.date == resource.data.date
        && validAttendance(request.resource.data, docId);
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid
        && docId == request.auth.uid + '_' + resource.data.date;
    }
  }
}
